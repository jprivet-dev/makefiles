#
# COLORS
#

RESET     = "\\033[0m"
BLUE      = "\\033[34m"
GREEN     = "\\033[32m"
RED       = "\\033[31m"
YELLOW    = "\\033[33m"
UNDERLINE = "\\033[4m"

#
# EXECUTABLES (LOCAL)
#

ALIASES = scripts/autogenerated-aliases.sh

## — 👾 🚀 THE ALIASES MAKEFILE 🚀 👾 —————————————————————————————————————————

# Print self-documented Makefile:
# $ make
# $ make help

.DEFAULT_GOAL = help
.PHONY: help
help: ## Print self-documented Makefile
	@grep -E '(^[.a-zA-Z_-]+[^:]+:.*##.*?$$)|(^#{2})' Makefile \
	| awk 'BEGIN {FS = "## "}; \
		{ \
			split($$1, line, ":"); \
			targets=line[1]; \
			description=$$2; \
			if (targets == "##") { \
				# --- space --- \
				printf "\033[33m%s\n", ""; \
			} else if (targets == "" && description != "") { \
				# --- title --- \
				printf "\033[33m\n%s\n", description; \
			} else if (targets != "" && description != "") { \
				# --- target, alias, description --- \
				split(targets, parts, " "); \
				target=parts[1]; \
				alias=parts[2]; \
				printf "\033[32m  %-26s \033[34m%-2s \033[0m%s\n", target, alias, description; \
			} \
		}'
	@echo

## — FOO 🚀 ———————————————————————————————————————————————————————————————————

.PHONY: foo
foo: ## Foo
	printf "Foo\n"

.PHONY: bar
bar: ## Bar
	printf "Bar\n"

## — UTILS 🛠️  —————————————————————————————————————————————————————————————————

.PHONY: aliases
aliases: ## Auto generate aliases
	@>$(ALIASES)
	@printf "\n"
	@printf "Create $(YELLOW)$(ALIASES)$(RESET) file:\n"
	@echo '#' >>$(ALIASES)
	@echo '# Auto-generated aliases ($(shell date +"%Y%m%d-%H%M%S"))' >>$(ALIASES)
	@echo '#' >>$(ALIASES)
	@echo 'alias foo="make foo"' >>$(ALIASES)
	@echo 'alias bar="make bar"' >>$(ALIASES)
	@echo 'printf "🎉 Auto-generated aliases loaded 🎉\\n"' >>$(ALIASES)
	@cat $(ALIASES)
	@printf "\n"
	@printf "Load aliases with $(YELLOW)$$ . $(ALIASES)$(RESET)\n"
